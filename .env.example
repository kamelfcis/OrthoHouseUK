# Supabase — copy to .env and fill in your project values
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Unsplash — Access Key only (never commit the Secret Key; not used in this SPA)
# https://unsplash.com/oauth/applications
VITE_UNSPLASH_ACCESS_KEY=your_access_key_here

# Pexels — API key for free stock videos (homepage hero backgrounds)
# https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key

