# Supabase — copy to .env and fill in your project values
# Dashboard: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: database password for scripts/seed_social_links.py and
# scripts/upload_partner_portfolios.py to apply migrations locally
# SUPABASE_DB_PASSWORD=your-database-password

# Resend — portfolio request emails (Edge Function secrets only; never in .env or client)
# Set via Supabase Dashboard → Edge Functions → send-portfolio → Secrets, or:
#   supabase secrets set RESEND_API_KEY=re_... PORTFOLIO_FROM_EMAIL=onboarding@resend.dev SITE_URL=https://ortho-house-uk.vercel.app
# onboarding@resend.dev works without domain verification (Resend test sender).
# Switch PORTFOLIO_FROM_EMAIL to a verified domain address before production.
# RESEND_API_KEY=re_your_api_key
# PORTFOLIO_FROM_EMAIL=onboarding@resend.dev
# SITE_URL=https://ortho-house-uk.vercel.app

# Unsplash — Access Key only (never commit the Secret Key; not used in this SPA)
# https://unsplash.com/oauth/applications
VITE_UNSPLASH_ACCESS_KEY=your_access_key_here

# Pexels — API key for free stock videos (homepage hero backgrounds)
# https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key

